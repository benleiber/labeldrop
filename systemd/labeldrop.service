[Unit]
Description=LabelDrop local print server
After=network.target

[Service]
Type=simple
User=ben
WorkingDirectory=/home/ben/labeldrop
Environment=LABELDROP_DEVICE=/dev/usb/lp0
Environment=LABELDROP_DATA_DIR=data
Environment=LABELDROP_HOST=0.0.0.0
Environment=LABELDROP_PORT=8000
ExecStart=/home/ben/labeldrop/.venv/bin/uvicorn labeldrop.app:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
